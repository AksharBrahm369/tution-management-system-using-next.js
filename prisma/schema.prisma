  @@index([instituteId])
  @@map("announcements")
}

// Enums for Reports & Analytics
enum ReportType {
  FINANCIAL
  ACADEMIC
  ATTENDANCE
  STUDENT_PROGRESS
  TEACHER_PERFORMANCE
  BATCH_PERFORMANCE
  INSTITUTE_OVERVIEW
  CUSTOM
}

enum ReportCategory {
  STANDARD
  CUSTOM
  SCHEDULED
  SYSTEM
}

enum ScheduleFreq {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum RunType {
  MANUAL
  SCHEDULED
  AUTO
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum SnapshotType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

// Reports & Analytics Models
model Report {
  id String @id @default(cuid())
  instituteId String?

  // Identity
  name        String
  description String?
  type        ReportType
  category    ReportCategory

  // Config
  config    Json
  filters   Json?
  columns   String[]
  groupBy   String?
  sortBy    String?
  sortOrder String?

  // Schedule
  isScheduled       Boolean       @default(false)
  scheduleFrequency ScheduleFreq?
  scheduleDay       Int?
  scheduleTime      String?
  lastRunAt         DateTime?
  nextRunAt         DateTime?

  // Email
  emailEnabled    Boolean  @default(false)
  emailRecipients String[]

  // Status
  isActive   Boolean @default(true)
  isFavorite Boolean @default(false)
  isDefault  Boolean @default(false)

  createdBy String
  runs      ReportRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([instituteId])

  @@map("reports")
}

model ReportRun {
  id String @id @default(cuid())
  instituteId String?

  reportId String
  runBy    String
  runType  RunType @default(MANUAL)

  // Status
  status       RunStatus @default(PENDING)
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  errorMessage String?

  // Output
  rowCount Int?
  fileUrl  String?
  fileType String?
  fileSize String?

  // Filters used
  filtersUsed Json?
  dateRange   Json?

  report Report @relation(fields: [reportId], references: [id])

  createdAt DateTime @default(now())
  @@index([instituteId])

  @@map("report_runs")
}

model AnalyticsSnapshot {
  id String @id @default(cuid())
  instituteId String?

  date DateTime
  type SnapshotType

  // Student Metrics
  totalStudents  Int @default(0)
  activeStudents Int @default(0)
  newStudents    Int @default(0)
  leftStudents   Int @default(0)

  // Attendance Metrics
  avgAttendance Float @default(0)
  presentCount  Int   @default(0)
  absentCount   Int   @default(0)

  // Fee Metrics
  feeDue         Float @default(0)
  feeCollected   Float @default(0)
  feePending     Float @default(0)
  collectionRate Float @default(0)

  // Exam Metrics
  examsHeld    Int   @default(0)
  avgExamScore Float @default(0)
  passRate     Float @default(0)

  // Communication Metrics
  messagesSent Int   @default(0)
  deliveryRate Float @default(0)

  createdAt DateTime @default(now())

  @@unique([date, type])
  @@index([instituteId])
  @@map("analytics_snapshots")
}

model StudentProgressReport {
  id String @id @default(cuid())
  instituteId String?

  studentId String
  batchId   String
  month     Int
  year      Int

  // Attendance
  attendancePercent Float @default(0)
  classesPresent    Int   @default(0)
  classesAbsent     Int   @default(0)

  // Academic
  examsTaken   Int     @default(0)
  avgScore     Float   @default(0)
  highestScore Float   @default(0)
  lowestScore  Float   @default(0)
  avgGrade     String?

  // Fee
  feeStatus  String?
  feePaid    Float   @default(0)
  feePending Float   @default(0)

  // Rank
  batchRank    Int?
  totalInBatch Int?

  // Overall
  overallRating  String?
  teacherComment String?
  adminComment   String?

  student Student @relation(fields: [studentId], references: [id])

  generatedAt DateTime @default(now())

  @@unique([studentId, batchId, month, year])
  @@index([instituteId])
  @@map("student_progress_reports")
}

model PTMMeeting {
  id          String    @id @default(cuid())
  instituteId String?
  title       String
  description String?
  meetingDate DateTime
  startTime   String
  endTime     String
  venue       String?

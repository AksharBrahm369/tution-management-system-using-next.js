}

// Announcements model (Module: Communication)
enum AnnouncementStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  CANCELLED
}

model Announcement {
  id         String             @id @default(cuid())
  userId     String
  title      String
  message    String
  audience   String             @default("ALL")
  channels   String? // comma-separated channels (WHATSAPP,SMS,EMAIL)
  scheduleAt DateTime?
  status     AnnouncementStatus @default(DRAFT)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("announcements")
}

// Enums for Reports & Analytics
enum ReportType {
  FINANCIAL
  ACADEMIC
  ATTENDANCE
  STUDENT_PROGRESS
  TEACHER_PERFORMANCE
  BATCH_PERFORMANCE
  INSTITUTE_OVERVIEW
  CUSTOM
}

enum ReportCategory {
  STANDARD
  CUSTOM
  SCHEDULED
  SYSTEM
}

enum ScheduleFreq {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum RunType {
  MANUAL
  SCHEDULED
  AUTO
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum SnapshotType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

// Reports & Analytics Models
model Report {
  id String @id @default(cuid())

  // Identity
  name        String
  description String?
  type        ReportType
  category    ReportCategory

  // Config
  config    Json
  filters   Json?
  columns   String[]
  groupBy   String?
  sortBy    String?
  sortOrder String?

  // Schedule
  isScheduled       Boolean       @default(false)
  scheduleFrequency ScheduleFreq?
  scheduleDay       Int?
  scheduleTime      String?
  lastRunAt         DateTime?
  nextRunAt         DateTime?

  // Email
  emailEnabled    Boolean  @default(false)
  emailRecipients String[]

  // Status
  isActive   Boolean @default(true)
  isFavorite Boolean @default(false)
  isDefault  Boolean @default(false)

  createdBy String
  runs      ReportRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reports")
}

model ReportRun {
  id String @id @default(cuid())

  reportId String
  runBy    String
  runType  RunType @default(MANUAL)

  // Status
  status       RunStatus @default(PENDING)
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  errorMessage String?

  // Output
  rowCount Int?
  fileUrl  String?
  fileType String?
  fileSize String?

  // Filters used
  filtersUsed Json?
  dateRange   Json?

  report Report @relation(fields: [reportId], references: [id])

  createdAt DateTime @default(now())

  @@map("report_runs")
}

model AnalyticsSnapshot {
  id String @id @default(cuid())

  date DateTime
  type SnapshotType

  // Student Metrics
  totalStudents  Int @default(0)
  activeStudents Int @default(0)
  newStudents    Int @default(0)
  leftStudents   Int @default(0)

  // Attendance Metrics
  avgAttendance Float @default(0)
  presentCount  Int   @default(0)
  absentCount   Int   @default(0)

  // Fee Metrics
  feeDue         Float @default(0)
  feeCollected   Float @default(0)
  feePending     Float @default(0)
  collectionRate Float @default(0)

  // Exam Metrics
  examsHeld    Int   @default(0)
  avgExamScore Float @default(0)
  passRate     Float @default(0)

  // Communication Metrics
  messagesSent Int   @default(0)
  deliveryRate Float @default(0)

  createdAt DateTime @default(now())

  @@unique([date, type])
  @@map("analytics_snapshots")
}

model StudentProgressReport {
  id String @id @default(cuid())

  studentId String
  batchId   String
  month     Int
  year      Int

  // Attendance
  attendancePercent Float @default(0)
  classesPresent    Int   @default(0)
  classesAbsent     Int   @default(0)

  // Academic
  examsTaken   Int     @default(0)
  avgScore     Float   @default(0)
  highestScore Float   @default(0)
  lowestScore  Float   @default(0)
  avgGrade     String?

  // Fee
  feeStatus  String?
  feePaid    Float   @default(0)
  feePending Float   @default(0)

  // Rank
  batchRank    Int?
  totalInBatch Int?

  // Overall
  overallRating  String?
  teacherComment String?
  adminComment   String?

  student Student @relation(fields: [studentId], references: [id])

  generatedAt DateTime @default(now())

  @@unique([studentId, batchId, month, year])
  @@map("student_progress_reports")
}

model PTMMeeting {
  id          String    @id @default(cuid())
  title       String
  description String?
  meetingDate DateTime
  startTime   String
  endTime     String
  venue       String?
  isOnline    Boolean   @default(false)
  meetingLink String?
  batchId     String?
  isForAll    Boolean   @default(true)
  status      PTMStatus @default(SCHEDULED)

  slots PTMSlot[]

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingDate])
  @@index([batchId])
  @@map("ptm_meetings")
}

model PTMSlot {
  id             String     @id @default(cuid())
  meetingId      String
  parentId       String
  studentId      String
  teacherId      String?
  slotTime       String
  duration       Int        @default(15)
  status         SlotStatus @default(BOOKED)
  notes          String?
  adminNotes     String?
  parentFeedback String?

  meeting PTMMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  parent  Parent     @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher?   @relation(fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([meetingId, parentId, studentId])
  @@index([meetingId])
  @@index([parentId])
  @@index([studentId])
  @@map("ptm_slots")
}

model ParentFeedback {
  id            String         @id @default(cuid())
  parentId      String
  studentId     String
  teacherId     String?
  batchId       String?
  subject       String
  message       String
  type          FeedbackType
  rating        Int?
  status        FeedbackStatus @default(OPEN)
  adminResponse String?
  respondedBy   String?
  respondedAt   DateTime?

  parent  Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher? @relation(fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([studentId])
  @@index([status])
  @@map("parent_feedbacks")
}

model TeacherPerformanceReport {
  id String @id @default(cuid())

  teacherId String
  month     Int
  year      Int

  // Attendance
  attendancePercent Float @default(0)
  daysPresent       Int   @default(0)
  daysAbsent        Int   @default(0)

  // Classes
  classesScheduled Int @default(0)
  classesTaken     Int @default(0)
  classesCancelled Int @default(0)

  // Student Performance
  avgStudentScore Float @default(0)
  studentPassRate Float @default(0)

  // Salary
  salaryStatus String?
  salaryAmount Float   @default(0)

  // Rating
  rating     Float?
  adminNotes String?

  teacher Teacher @relation(fields: [teacherId], references: [id])

  generatedAt DateTime @default(now())

  @@unique([teacherId, month, year])
  @@map("teacher_performance_reports")
}

model Exam {
  id String @id @default(cuid())

  title       String
  code        String   @unique
  description String?
  type        ExamType

  batchId      String
  subjectId    String
  standardId   String?
  academicYear String

  examDate  DateTime
  startTime String?
  endTime   String?
  duration  Int?

  totalMarks         Float
  passingMarks       Float
  hasNegativeMarking Boolean @default(false)
  negativeMarkValue  Float   @default(0)

  gradingSystem GradingSystem @default(PERCENTAGE)
  gradeConfig   Json?

  status            ExamStatus @default(UPCOMING)
  isResultPublished Boolean    @default(false)
  resultPublishedAt DateTime?
  publishedBy       String?

  batch          Batch           @relation(fields: [batchId], references: [id])
  subject        Subject         @relation(fields: [subjectId], references: [id])
  standard       Standard?       @relation(fields: [standardId], references: [id], onDelete: SetNull)
  results        ExamResult[]
  questions      ExamQuestion[]
  onlineAttempts OnlineAttempt[]
  createdBy      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@index([subjectId])
  @@index([standardId])
  @@index([status])
  @@index([examDate])
  @@map("exams")
}

model ExamResult {
  id String @id @default(cuid())

  examId    String
  studentId String
  batchId   String

  marksObtained Float?
  totalMarks    Float
  percentage    Float?

  grade      String?
  gradePoint Float?

  batchRank   Int?
  overallRank Int?

  status           ResultStatus @default(PENDING)
  isAbsent         Boolean      @default(false)
  isDisqualified   Boolean      @default(false)
  disqualifyReason String?

  answerSheetUrl String?

  teacherRemarks String?
  strengthAreas  String[]
  weakAreas      String[]

  enteredBy  String?
  enteredAt  DateTime?
  verifiedBy String?
  verifiedAt DateTime?

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examId, studentId])
  @@index([batchId, examId])
  @@index([studentId])
  @@map("exam_results")
}

model ExamQuestion {
  id String @id @default(cuid())

  examId         String
  questionNumber Int
  questionText   String
  questionType   QuestionType
  marks          Float
  negativeMarks  Float        @default(0)

  optionA       String?
  optionB       String?
  optionC       String?
  optionD       String?
  correctOption String?

  modelAnswer     String?
  answerKeyPoints String[]

  topic      String?
  difficulty Difficulty @default(MEDIUM)

  exam           Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentAnswers StudentAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examId, questionNumber])
  @@map("exam_questions")
}

model StudentAnswer {
  id String @id @default(cuid())

  questionId String
  studentId  String
  attemptId  String?

  selectedOption String?
  writtenAnswer  String?
  marksAwarded   Float?
  isCorrect      Boolean?

  question ExamQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  student  Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attempt  OnlineAttempt? @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([questionId])
  @@index([studentId])
  @@index([attemptId])
  @@map("student_answers")
}

model OnlineAttempt {
  id String @id @default(cuid())

  examId    String
  studentId String

  startedAt        DateTime?
  submittedAt      DateTime?
  timeSpentMinutes Int?

  status AttemptStatus @default(NOT_STARTED)

  autoScore  Float?
  finalScore Float?

  tabSwitchCount  Int     @default(0)
  isTerminated    Boolean @default(false)
  terminateReason String?

  exam    Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers StudentAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examId, studentId])
  @@index([studentId])
  @@map("online_attempts")
}

model GradeConfig {
  id String @id @default(cuid())

  name        String
  description String?
  isDefault   Boolean @default(false)

  grades GradeRange[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("grade_configs")
}

model GradeRange {
  id String @id @default(cuid())

  configId      String
  grade         String
  minPercentage Float
  maxPercentage Float
  gradePoint    Float
  remark        String?
  color         String?

  config GradeConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([configId])
  @@map("grade_ranges")
}

model ReportCard {
  id String @id @default(cuid())

  studentId    String
  batchId      String
  academicYear String
  term         String
  generatedAt  DateTime @default(now())
  generatedBy  String
  pdfUrl       String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([studentId, batchId, academicYear, term])
  @@index([batchId])
  @@map("report_cards")
}

model PerformanceAnalysis {
  id String @id @default(cuid())

  studentId String
  batchId   String
  subjectId String
  month     Int
  year      Int

  avgScore        Float
  highestScore    Float
  lowestScore     Float
  examsTaken      Int
  examsAbsent     Int
  improvementRate Float?

  strongTopics String[]
  weakTopics   String[]

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, batchId, month, year])
  @@index([subjectId])
  @@map("performance_analysis")
}

model StudentActivity {
  id            String  @id @default(cuid())
  studentId     String
  type          String
  title         String
  description   String
  metadata      Json?
  performedById String?

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  performedBy User?    @relation("StudentActivityPerformedBy", fields: [performedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([studentId])
  @@index([createdAt])
  @@map("student_activities")
}

// ─── Module 4: Teacher Management ────────────────────────────────────────────

model Teacher {
  id String @id @default(cuid())

  // Basic Info
  teacherCode    String      @unique
  firstName      String
  lastName       String
  email          String      @unique
  phone          String
  alternatePhone String?
  dateOfBirth    DateTime?
  gender         Gender
  bloodGroup     BloodGroup?
  profilePhoto   String?

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  pincode      String?

  // Professional Info
  qualification  String?
  specialization String?
  experience     Int?
  joiningDate    DateTime       @default(now())
  employmentType EmploymentType @default(FULL_TIME)

  // Salary Info
  salaryType     SalaryType @default(FIXED)
  fixedSalary    Float?
  perClassRate   Float?
  perStudentRate Float?

  // Bank Details
  bankName      String?
  accountNumber String?
  ifscCode      String?
  upiId         String?

  // Status
  status TeacherStatus @default(ACTIVE)

  // Login Access
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  // Relations
  subjects                  TeacherSubject[]
  standardSubjects          TeacherStandardSubject[]
  batches                   Batch[]
  attendance                TeacherAttendance[]
  leaves                    TeacherLeave[]
  salaryRecords             SalaryRecord[]
  documents                 TeacherDocument[]
  performance               TeacherPerformance[]
  // Reports relation
  teacherPerformanceReports TeacherPerformanceReport[]
  ptmSlots                  PTMSlot[]
  parentFeedbacks           ParentFeedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teachers")
}

model Subject {
  id          String  @id @default(cuid())
  name        String
  code        String  @unique
  description String?
  isActive    Boolean @default(true)

  teachers                TeacherSubject[]
  teacherStandardSubjects TeacherStandardSubject[]
  batches                 Batch[]
  exams                   Exam[]
  materials               StudyMaterial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subjects")
}

model StudyMaterial {
  id String @id @default(cuid())

  title        String
  description  String?
  subjectId    String?
  batchId      String?
  standardId   String?
  resourceType String
  accessLevel  String  @default("PUBLIC")
  resourceUrl  String?
  fileName     String?
  fileSize     String?
  createdBy    String?

  subject  Subject?  @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  batch    Batch?    @relation(fields: [batchId], references: [id], onDelete: SetNull)
  standard Standard? @relation(fields: [standardId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectId])
  @@index([batchId])
  @@index([standardId])
  @@index([accessLevel])
  @@map("study_materials")
}

model TeacherSubject {
  id        String  @id @default(cuid())
  teacherId String
  subjectId String
  isPrimary Boolean @default(false)

  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  createdAt DateTime @default(now())

  @@unique([teacherId, subjectId])
  @@map("teacher_subjects")
}

model TeacherStandardSubject {
  id         String @id @default(cuid())
  teacherId  String
  standardId String
  subjectId  String

  teacher  Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  standard Standard @relation(fields: [standardId], references: [id], onDelete: Cascade)
  subject  Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([teacherId, standardId, subjectId])
  @@index([standardId])
  @@index([subjectId])
  @@map("teacher_standard_subjects")
}

model TeacherAttendance {
  id        String            @id @default(cuid())
  teacherId String
  date      DateTime
  status    TeacherAttdStatus @default(PRESENT)
  checkIn   DateTime?
  checkOut  DateTime?
  notes     String?
  markedBy  String

  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  createdAt DateTime @default(now())

  @@unique([teacherId, date])
  @@map("teacher_attendance")
}

model TeacherLeave {
  id           String      @id @default(cuid())
  teacherId    String
  leaveType    LeaveType
  fromDate     DateTime
  toDate       DateTime
  totalDays    Int
  reason       String
  status       LeaveStatus @default(PENDING)
  reviewedBy   String?
  reviewNote   String?
  reviewedAt   DateTime?
  substituteId String?

  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teacher_leaves")
}

model SalaryRecord {
  id        String @id @default(cuid())
  teacherId String
  month     Int
  year      Int

  // Calculation
  baseSalary    Float
  classesHeld   Int   @default(0)
  studentCount  Int   @default(0)
  calculatedPay Float

  // Adjustments
  bonus       Float @default(0)
  deductions  Float @default(0)
  finalAmount Float

  // Payment
  status        PaymentStatus @default(PENDING)
  paidDate      DateTime?
  paymentMode   String?
  transactionId String?
  notes         String?

  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, month, year])
  @@map("salary_records")
}

model TeacherDocument {
  id         String         @id @default(cuid())
  teacherId  String
  name       String
  type       TeacherDocType
  fileUrl    String
  fileSize   String?
  expiryDate DateTime?
  uploadedAt DateTime       @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@map("teacher_documents")
}

model TeacherPerformance {
  id        String @id @default(cuid())
  teacherId String
  month     Int
  year      Int

  // Metrics
  totalClasses     Int     @default(0)
  classesTaken     Int     @default(0)
  avgRating        Float?
  studentsFeedback String?
  adminNotes       String?

  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  createdAt DateTime @default(now())

  @@unique([teacherId, month, year])
  @@map("teacher_performance")
}

// ─── Module 5: Batch & Schedule Management ───────────────────────────────────

model Room {
  id         String   @id @default(cuid())
  name       String
  code       String   @unique
  capacity   Int
  floor      String?
  building   String?
  facilities String[]
  isActive   Boolean  @default(true)

  batches  Batch[]
  sessions ClassSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rooms")
}

model Batch {
  id String @id @default(cuid())

  // Identity
  name        String
  code        String  @unique
  description String?
  color       String?

  // Subject and Teacher
  subjectId  String
  teacherId  String
  standardId String?

  // Schedule
  days            DayOfWeek[]
  startTime       String
  endTime         String
  durationMinutes Int         @default(0)

  // Room
  roomId String?

  // Capacity
  maxStrength     Int @default(30)
  currentStrength Int @default(0)

  // Academic
  academicYear String
  startDate    DateTime
  endDate      DateTime?
  fees         Float     @default(0)

  // Status
  status      BatchStatus @default(ACTIVE)
  isOnline    Boolean     @default(false)
  meetingLink String?

  // Relations
  subject                 Subject                  @relation(fields: [subjectId], references: [id])
  teacher                 Teacher                  @relation(fields: [teacherId], references: [id])
  standard                Standard?                @relation(fields: [standardId], references: [id], onDelete: SetNull)
  room                    Room?                    @relation(fields: [roomId], references: [id])
  enrollments             BatchEnrollment[]
  sessions                ClassSession[]
  attendance              Attendance[]
  attendanceSessions      AttendanceSession[]
  attendanceAlerts        AttendanceAlert[]
  attendanceNotifications AttendanceNotification[]
  timetableSlots          TimetableSlot[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  feeStructures FeeStructure[]
  feeRecords    FeeRecord[]
  exams         Exam[]
  materials     StudyMaterial[]

  @@index([code])
  @@index([status])
  @@index([academicYear])
  @@index([teacherId])
  @@index([subjectId])
  @@index([standardId])
  @@map("batches")
}

model BatchEnrollment {
  id         String    @id @default(cuid())
  studentId  String
  batchId    String
  enrollDate DateTime  @default(now())
  leaveDate  DateTime?
  isActive   Boolean   @default(true)
  enrolledBy String
  notes      String?

  student Student @relation(fields: [studentId], references: [id])
  batch   Batch   @relation(fields: [batchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, batchId])
  @@index([studentId])
  @@index([batchId])
  @@map("batch_enrollments")
}

model TimetableSlot {
  id        String    @id @default(cuid())
  batchId   String
  day       DayOfWeek
  startTime String
  endTime   String
  roomId    String?
  isActive  Boolean   @default(true)

  batch Batch @relation(fields: [batchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@map("timetable_slots")
}

model ClassSession {
  id String @id @default(cuid())

  batchId    String
  teacherId  String
  roomId     String?
  standardId String?

  // Schedule
  date            DateTime
  startTime       String
  endTime         String
  durationMinutes Int

  // Content
  topic           String?
  description     String?
  homework        String?
  isAutoGenerated Boolean @default(false)

  // Status
  status       SessionStatus @default(SCHEDULED)
  cancelReason String?
  cancelledBy  String?
  cancelledAt  DateTime?

  // Reschedule
  isRescheduled    Boolean   @default(false)
  originalDate     DateTime?
  rescheduledTo    DateTime?
  rescheduleReason String?

  // Substitute
  hasSubstitute Boolean @default(false)
  substituteId  String?

  // Relations
  batch      Batch        @relation(fields: [batchId], references: [id])
  standard   Standard?    @relation(fields: [standardId], references: [id], onDelete: SetNull)
  room       Room?        @relation(fields: [roomId], references: [id])
  attendance Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@index([standardId])
  @@index([date])
  @@index([status])
  @@map("class_sessions")
}

model Holiday {
  id          String      @id @default(cuid())
  name        String
  date        DateTime
  type        HolidayType
  description String?
  isRecurring Boolean     @default(false)
  affectsAll  Boolean     @default(true)
  batchIds    String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@map("holidays")
}

model AcademicCalendar {
  id          String            @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  type        CalendarEventType
  color       String?
  isAllDay    Boolean           @default(true)
  batchIds    String[]
  createdBy   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
  @@map("academic_calendar")
}

model ConflictLog {
  id          String       @id @default(cuid())
  type        ConflictType
  description String
  batchId     String?
  teacherId   String?
  roomId      String?
  date        DateTime?
  timeSlot    String?
  isResolved  Boolean      @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?

  createdAt DateTime @default(now())

  @@index([isResolved])
  @@map("conflict_logs")
}

// ─── Legacy ClassSchedule (kept for backward compatibility) ──────────────────

model ClassSchedule {
  id           String      @id @default(cuid())
  batchId      String
  date         DateTime
  startTime    String
  endTime      String
  topic        String?
  status       ClassStatus @default(SCHEDULED)
  cancelReason String?
  substituteId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("class_schedules")
}

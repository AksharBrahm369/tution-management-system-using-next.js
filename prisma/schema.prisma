model PTMSlot {
  id             String     @id @default(cuid())
  instituteId String?
  meetingId      String
  parentId       String
  studentId      String
  teacherId      String?
  slotTime       String
  duration       Int        @default(15)
  status         SlotStatus @default(BOOKED)
  notes          String?
  adminNotes     String?
  parentFeedback String?

  meeting PTMMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  parent  Parent     @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher?   @relation(fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([meetingId, parentId, studentId])
  @@index([meetingId])
  @@index([parentId])
  @@index([studentId])
  @@index([instituteId])
  @@map("ptm_slots")
}

model ParentFeedback {
  id            String         @id @default(cuid())
  instituteId String?
  parentId      String
  studentId     String
  teacherId     String?
  batchId       String?
  subject       String
  message       String
  type          FeedbackType
  rating        Int?
  status        FeedbackStatus @default(OPEN)
  adminResponse String?
  respondedBy   String?
  respondedAt   DateTime?

  parent  Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher? @relation(fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([studentId])
  @@index([status])
  @@index([instituteId])
  @@map("parent_feedbacks")
}

model TeacherPerformanceReport {
  id String @id @default(cuid())
  instituteId String?

  teacherId String
  month     Int
  year      Int

  // Attendance
  attendancePercent Float @default(0)
  daysPresent       Int   @default(0)
  daysAbsent        Int   @default(0)

  // Classes
  classesScheduled Int @default(0)
  classesTaken     Int @default(0)
  classesCancelled Int @default(0)

  // Student Performance
  avgStudentScore Float @default(0)
  studentPassRate Float @default(0)

  // Salary
  salaryStatus String?
  salaryAmount Float   @default(0)

  // Rating
  rating     Float?
  adminNotes String?

  teacher Teacher @relation(fields: [teacherId], references: [id])

  generatedAt DateTime @default(now())

  @@unique([teacherId, month, year])
  @@index([instituteId])
  @@map("teacher_performance_reports")
}

model Exam {
  id String @id @default(cuid())
  instituteId String?

  title       String
  code        String
  description String?
  type        ExamType

  batchId      String
  subjectId    String
  standardId   String?
  academicYear String

  examDate  DateTime
  startTime String?
  endTime   String?
  duration  Int?

  totalMarks         Float
  passingMarks       Float
  hasNegativeMarking Boolean @default(false)
  negativeMarkValue  Float   @default(0)

  gradingSystem GradingSystem @default(PERCENTAGE)
  gradeConfig   Json?

  status            ExamStatus @default(UPCOMING)
  isResultPublished Boolean    @default(false)
  resultPublishedAt DateTime?
  publishedBy       String?

  batch          Batch           @relation(fields: [batchId], references: [id])
  subject        Subject         @relation(fields: [subjectId], references: [id])
  standard       Standard?       @relation(fields: [standardId], references: [id], onDelete: SetNull)
  results        ExamResult[]
  questions      ExamQuestion[]
  onlineAttempts OnlineAttempt[]
  createdBy      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instituteId, code])
  @@index([batchId])
  @@index([subjectId])
  @@index([standardId])
  @@index([status])
  @@index([examDate])
  @@index([instituteId])
  @@map("exams")
}

model ExamResult {
  id String @id @default(cuid())
  instituteId String?

  examId    String
  studentId String
  batchId   String

  marksObtained Float?
  totalMarks    Float
  percentage    Float?

  grade      String?
  gradePoint Float?

  batchRank   Int?
  overallRank Int?

  status           ResultStatus @default(PENDING)
  isAbsent         Boolean      @default(false)
  isDisqualified   Boolean      @default(false)
  disqualifyReason String?

  answerSheetUrl String?

  teacherRemarks String?
  strengthAreas  String[]
  weakAreas      String[]

  enteredBy  String?
  enteredAt  DateTime?
  verifiedBy String?
  verifiedAt DateTime?

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examId, studentId])
  @@index([batchId, examId])
  @@index([studentId])
  @@index([instituteId])
  @@map("exam_results")
}

model ExamQuestion {
  id String @id @default(cuid())
  instituteId String?

  examId         String
  questionNumber Int
  questionText   String
  questionType   QuestionType
  marks          Float
  negativeMarks  Float        @default(0)

  optionA       String?
  optionB       String?
  optionC       String?
  optionD       String?
  correctOption String?

  modelAnswer     String?
  answerKeyPoints String[]

  topic      String?
  difficulty Difficulty @default(MEDIUM)

  exam           Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentAnswers StudentAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


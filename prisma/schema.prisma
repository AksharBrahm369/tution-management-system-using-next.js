// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  password   String
  phone      String?
  role       Role      @default(STUDENT)
  avatar     String?
  isActive   Boolean   @default(true)
  isVerified Boolean   @default(false)
  lastLogin  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  sessions          Session[]
  activityLogs      ActivityLog[]
  notifications     Notification[]
  announcements     Announcement[]
  students          Student[]
  parents           Parent[]
  teacher           Teacher?
  studentActivities StudentActivity[] @relation("StudentActivityPerformedBy")

  @@index([email])
  @@index([role])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model OTPVerification {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("otp_verifications")
}

model ActivityLog {
  id String @id @default(cuid())

  // Who
  userId    String?
  userName  String?
  userRole  Role?
  ipAddress String?
  userAgent String?

  // What
  action   String
  category LogCategory @default(SYSTEM)
  severity LogSeverity @default(INFO)

  // On What
  entityType String?
  entityId   String?
  entityName String?

  // Details
  description String @default("")
  oldValue    Json?
  newValue    Json?
  metadata    Json?

  // Status
  isSuccessful Boolean @default(true)
  errorMessage String?

  createdAt DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([category])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([severity])
  @@map("activity_logs")
}

// Password reset tokens stored separately for security
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

// ─── Module 2: Admin Dashboard ───────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  studentId String?
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([studentId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Enquiry {
  id            String @id @default(cuid())
  enquiryNumber String @unique

  studentName  String
  studentAge   Int?
  studentClass String?
  parentName   String
  parentPhone  String
  parentEmail  String?
  address      String?

  interestedIn   String[]
  preferredBatch String?
  preferredTime  String?

  source       EnquirySource
  sourceDetail String?
  referredBy   String?

  status   EnquiryStatus @default(NEW)
  priority Priority      @default(NORMAL)

  assignedTo String?
  assignedAt DateTime?

  isConverted Boolean   @default(false)
  convertedAt DateTime?
  studentId   String?

  notes String?

  followUps   FollowUp[]
  demoClasses DemoClass[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([source])
  @@index([priority])
  @@index([assignedTo])
  @@index([createdAt])
  @@map("enquiries")
}

model FollowUp {
  id             String         @id @default(cuid())
  enquiryId      String
  type           FollowUpType
  scheduledAt    DateTime
  completedAt    DateTime?
  status         FollowUpStatus @default(PENDING)
  notes          String?
  outcome        String?
  nextFollowUpAt DateTime?
  doneBy         String?

  enquiry Enquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([enquiryId])
  @@index([status])
  @@index([scheduledAt])
  @@map("follow_ups")
}

model DemoClass {
  id             String     @id @default(cuid())
  enquiryId      String
  batchId        String?
  scheduledDate  DateTime
  scheduledTime  String
  status         DemoStatus @default(SCHEDULED)
  teacherNotes   String?
  parentFeedback String?
  interested     Boolean?

  enquiry Enquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enquiryId])
  @@index([status])
  @@index([scheduledDate])
  @@map("demo_classes")
}

model DashboardAlert {
  id         String    @id @default(cuid())
  type       AlertType
  message    String
  severity   Severity
  isResolved Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([severity])
  @@index([isResolved])
  @@index([createdAt])
  @@map("dashboard_alerts")
}

model InstituteSettings {
  id String @id @default(cuid())

  name        String
  tagline     String?
  description String?
  logo        String?
  favicon     String?

  phone          String?
  alternatePhone String?
  email          String?
  website        String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  pincode      String?
  country      String  @default("India")

  currentAcademicYear String
  academicYears       String[]
  workingDays         String[]
  workingHours        Json?

  gstEnabled    Boolean @default(false)
  gstNumber     String?
  gstPercentage Float   @default(18)
  panNumber     String?

  receiptPrefix      String  @default("RCP")
  receiptStartNumber String  @default("001")
  receiptFooterText  String?

  razorpayKeyId     String?
  razorpayKeySecret String?
  razorpayMode      String  @default("TEST")

  twilioAccountSid     String?
  twilioAuthToken      String?
  twilioWhatsAppNumber String?

  cloudinaryCloudName String?
  cloudinaryApiKey    String?
  cloudinaryApiSecret String?

  firebaseProjectId String?
  firebaseApiKey    String?

  passwordMinLength      Int     @default(8)
  requireUppercase       Boolean @default(true)
  requireNumber          Boolean @default(true)
  requireSpecialChar     Boolean @default(true)
  passwordExpiryDays     Int     @default(90)
  sessionTimeoutMinutes  Int     @default(30)
  rememberMeDays         Int     @default(7)
  maxFailedAttempts      Int     @default(5)
  lockoutDurationMinutes Int     @default(30)
  twoFactorEnabled       Boolean @default(false)

  autoBackupEnabled Boolean @default(false)
  backupFrequency   String  @default("WEEKLY")
  backupTime        String?
  backupRetention   Int     @default(10)

  currency   String @default("INR")
  dateFormat String @default("DD/MM/YYYY")
  timeFormat String @default("12H")
  language   String @default("EN")
  timezone   String @default("Asia/Kolkata")

  primaryColor   String @default("#2563EB")
  secondaryColor String @default("#10B981")

  onlinePaymentEnabled Boolean @default(false)
  qrAttendanceEnabled  Boolean @default(true)
  parentPortalEnabled  Boolean @default(true)
  studentPortalEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("institute_settings")
}

model AcademicYear {
  id        String   @id @default(cuid())
  name      String   @unique
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isCurrent])
  @@index([isActive])
  @@map("academic_years")
}

model BackupRecord {
  id          String       @id @default(cuid())
  fileName    String
  fileUrl     String?
  fileSize    String?
  type        BackupType
  status      BackupStatus @default(PENDING)
  triggeredBy String
  completedAt DateTime?
  errorMsg    String?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("backup_records")
}

// ─── Module 3: Student Management ────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  GRADUATED
  TRANSFERRED
  ON_LEAVE
}

enum StudentCategory {
  WEAK
  AVERAGE
  GOOD
  TOPPER
}

enum DocumentType {
  BIRTH_CERTIFICATE
  SCHOOL_LEAVING
  MARKSHEET
  ID_PROOF
  ADDRESS_PROOF
  MEDICAL
  PHOTO
  OTHER
}

model Student {
  id String @id @default(cuid())

  studentCode  String      @unique
  firstName    String
  lastName     String
  email        String?     @unique
  phone        String?
  dateOfBirth  DateTime?
  gender       Gender
  bloodGroup   BloodGroup?
  profilePhoto String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  pincode      String?

  previousSchool String?
  previousClass  String?
  previousMarks  String?
  joiningDate    DateTime @default(now())
  academicYear   String

  status     StudentStatus   @default(ACTIVE)
  category   StudentCategory @default(AVERAGE)
  referredBy String?
  standardId String?

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  parentId String?
  parent   Parent? @relation(fields: [parentId], references: [id])

  batchEnrollments        BatchEnrollment[]
  attendance              Attendance[]
  attendanceAlerts        AttendanceAlert[]
  attendanceNotifications AttendanceNotification[]
  feeRecords              FeeRecord[]
  examResults             ExamResult[]
  studentAnswers          StudentAnswer[]
  onlineAttempts          OnlineAttempt[]
  reportCards             ReportCard[]
  performanceAnalyses     PerformanceAnalysis[]
  documents               StudentDocument[]
  emergencyContacts       EmergencyContact[]
  medicalInfo             MedicalInfo?
  siblings                SiblingLink[]            @relation("StudentSiblings")
  siblingOf               SiblingLink[]            @relation("SiblingOfStudent")
  notifications           Notification[]
  activities              StudentActivity[]
  // Reports relation
  studentProgressReports  StudentProgressReport[]
  ptmSlots                PTMSlot[]
  parentFeedbacks         ParentFeedback[]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  discounts           Discount[]
  scholarships        Scholarship[]
  refunds             Refund[]
  onlinePaymentOrders OnlinePaymentOrder[]
  standard            Standard?            @relation(fields: [standardId], references: [id], onDelete: SetNull)

  @@index([studentCode])
  @@index([firstName, lastName])
  @@index([status])
  @@index([category])
  @@index([academicYear])
  @@index([standardId])
  @@map("students")
}

model Standard {
  id       String  @id @default(cuid())
  name     String  @unique
  order    Int     @unique
  isActive Boolean @default(true)

  students                Student[]
  batches                 Batch[]
  exams                   Exam[]
  materials               StudyMaterial[]
  classSessions           ClassSession[]
  teacherStandardSubjects TeacherStandardSubject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("standards")
}

model Parent {
  id             String  @id @default(cuid())
  parentCode     String? @unique
  fatherName     String?
  fatherPhone    String?
  fatherEmail    String?
  fatherOccup    String?
  motherName     String?
  motherPhone    String?
  motherEmail    String?
  motherOccup    String?
  guardianName   String?
  guardianPhone  String?
  guardianRel    String?
  primaryContact String  @default("FATHER")

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  students Student[]

  ptmSlots  PTMSlot[]
  feedbacks ParentFeedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("parents")
}

model EmergencyContact {
  id           String  @id @default(cuid())
  studentId    String
  name         String
  relationship String
  phone        String
  isVerified   Boolean @default(false)

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([studentId])
  @@map("emergency_contacts")
}

model MedicalInfo {
  id            String  @id @default(cuid())
  studentId     String  @unique
  allergies     String?
  medications   String?
  conditions    String?
  doctorName    String?
  doctorPhone   String?
  insuranceInfo String?
  extraNotes    String?

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("medical_info")
}

model StudentDocument {
  id         String       @id @default(cuid())
  studentId  String
  name       String
  type       DocumentType
  fileUrl    String
  fileSize   String?
  uploadedAt DateTime     @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_documents")
}

model SiblingLink {
  id        String @id @default(cuid())
  studentId String
  siblingId String

  student Student @relation("StudentSiblings", fields: [studentId], references: [id], onDelete: Cascade)
  sibling Student @relation("SiblingOfStudent", fields: [siblingId], references: [id], onDelete: Cascade)

  @@unique([studentId, siblingId])
  @@index([studentId])
  @@index([siblingId])
  @@map("sibling_links")
}

model Attendance {
  id               String            @id @default(cuid())
  studentId        String
  batchId          String
  sessionId        String?
  date             DateTime
  markedAt         DateTime          @default(now())
  markedBy         String
  status           AttendanceStatus  @default(ABSENT)
  lateMinutes      Int?
  arrivalTime      String?
  isLeaveApproved  Boolean           @default(false)
  leaveReason      String?
  markedViaQR      Boolean           @default(false)
  qrToken          String?
  isCorrected      Boolean           @default(false)
  correctedBy      String?
  correctedAt      DateTime?
  originalStatus   AttendanceStatus?
  correctionReason String?
  parentNotified   Boolean           @default(false)
  notifiedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  student Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batch   Batch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  session ClassSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@unique([studentId, batchId, date])
  @@index([batchId, date])
  @@index([studentId, date])
  @@map("attendance")
}

model AttendanceSession {
  id            String    @id @default(cuid())
  batchId       String
  sessionId     String?
  date          DateTime
  markedBy      String
  markedAt      DateTime  @default(now())
  isComplete    Boolean   @default(false)
  completedAt   DateTime?
  totalStudents Int       @default(0)
  presentCount  Int       @default(0)
  absentCount   Int       @default(0)
  lateCount     Int       @default(0)
  leaveCount    Int       @default(0)
  qrCode        String?   @unique
  qrExpiresAt   DateTime?
  qrIsActive    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, date])
  @@index([batchId, date])
  @@map("attendance_sessions")
}

model AttendanceAlert {
  id             String    @id @default(cuid())
  studentId      String
  batchId        String
  alertType      AlertType
  currentPercent Float
  threshold      Float
  message        String
  isRead         Boolean   @default(false)
  isResolved     Boolean   @default(false)
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batch   Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([batchId])
  @@index([isResolved])
  @@map("attendance_alerts")
}

model AttendanceNotification {
  id         String           @id @default(cuid())
  studentId  String
  batchId    String
  date       DateTime
  status     AttendanceStatus
  sentTo     String
  sentVia    String
  message    String
  isSent     Boolean          @default(false)
  sentAt     DateTime?
  failReason String?
  createdAt  DateTime         @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batch   Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([batchId])
  @@index([isSent])
  @@map("attendance_notifications")
}

// Fee management models (Module 7)

model FeeStructure {
  id String @id @default(cuid())

  name         String
  description  String?
  academicYear String

  tuitionFee   Float @default(0)
  admissionFee Float @default(0)
  examFee      Float @default(0)
  materialFee  Float @default(0)
  otherFee     Float @default(0)
  totalFee     Float @default(0)

  isGSTApplicable Boolean @default(false)
  gstPercentage   Float   @default(18)
  gstNumber       String?

  lateFeeEnabled   Boolean     @default(true)
  lateFeeType      LateFeeType @default(FIXED)
  lateFeeAmount    Float       @default(0)
  lateFeeAfterDays Int         @default(10)

  dueDateType DueDateType @default(DAY_OF_MONTH)
  dueDateDay  Int         @default(10)

  batchId    String?
  batch      Batch?      @relation(fields: [batchId], references: [id])
  feeRecords FeeRecord[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("fee_structures")
}

model FeeRecord {
  id String @id @default(cuid())

  receiptNumber  String  @unique
  studentId      String
  batchId        String
  feeStructureId String?

  month        Int
  year         Int
  academicYear String

  baseFee           Float
  discountAmount    Float   @default(0)
  discountReason    String?
  scholarshipAmount Float   @default(0)
  lateFee           Float   @default(0)
  otherCharges      Float   @default(0)
  totalAmount       Float
  paidAmount        Float   @default(0)
  pendingAmount     Float

  status   FeeStatus @default(PENDING)
  dueDate  DateTime
  paidDate DateTime?

  isGSTApplicable Boolean @default(false)
  gstAmount       Float   @default(0)
  gstNumber       String?

  student      Student       @relation(fields: [studentId], references: [id])
  batch        Batch         @relation(fields: [batchId], references: [id])
  feeStructure FeeStructure? @relation(fields: [feeStructureId], references: [id])
  payments     FeePayment[]
  reminders    FeeReminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, batchId, month, year])
  @@index([studentId, status])
  @@index([batchId, month, year])
  @@map("fee_records")
}

model FeePayment {
  id String @id @default(cuid())

  paymentNumber String @unique
  feeRecordId   String

  amount      Float
  paymentMode PaymentMode

  cashReceivedBy String?

  transactionId   String?
  gatewayName     String?
  gatewayResponse Json?

  chequeNumber String?
  chequeDate   DateTime?
  bankName     String?
  chequeStatus ChequeStatus?

  upiId            String?
  upiTransactionId String?

  status        PaymentStatus @default(COMPLETED)
  failureReason String?

  receiptUrl         String?
  receiptGeneratedAt DateTime?

  notes       String?
  collectedBy String

  feeRecord FeeRecord @relation(fields: [feeRecordId], references: [id])

  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("fee_payments")
}

model Discount {
  id String @id @default(cuid())

  studentId  String
  batchId    String?
  name       String
  type       DiscountType
  value      Float
  reason     String
  validFrom  DateTime
  validTo    DateTime?
  isActive   Boolean      @default(true)
  approvedBy String

  student Student @relation(fields: [studentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("discounts")
}

model Scholarship {
  id String @id @default(cuid())

  studentId   String
  name        String
  description String?
  amount      Float
  percentage  Float?
  validFrom   DateTime
  validTo     DateTime?
  isActive    Boolean   @default(true)
  criteria    String?
  approvedBy  String

  student Student @relation(fields: [studentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("scholarships")
}

model FeeReminder {
  id String @id @default(cuid())

  feeRecordId String
  studentId   String
  sentTo      String
  sentVia     ReminderChannel
  message     String
  status      ReminderStatus  @default(PENDING)
  sentAt      DateTime?
  failReason  String?

  feeRecord FeeRecord @relation(fields: [feeRecordId], references: [id])

  createdAt DateTime @default(now())

  @@map("fee_reminders")
}

model Refund {
  id String @id @default(cuid())

  paymentId     String
  studentId     String
  amount        Float
  reason        String
  status        RefundStatus @default(PENDING)
  processedBy   String?
  processedAt   DateTime?
  refundMode    PaymentMode?
  transactionId String?
  notes         String?

  student Student @relation(fields: [studentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("refunds")
}

model OnlinePaymentOrder {
  id String @id @default(cuid())

  orderId          String      @unique
  feeRecordId      String
  studentId        String
  amount           Float
  currency         String      @default("INR")
  status           OrderStatus @default(CREATED)
  gatewayOrderId   String?
  gatewayPaymentId String?
  gatewaySignature String?
  attempts         Int         @default(0)
  expiresAt        DateTime?

  student Student @relation(fields: [studentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


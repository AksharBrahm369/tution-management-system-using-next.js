  meetingLink String?
  batchId     String?
  isForAll    Boolean   @default(true)
  status      PTMStatus @default(SCHEDULED)

  slots PTMSlot[]

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


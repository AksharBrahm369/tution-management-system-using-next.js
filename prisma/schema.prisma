// Announcements model (Module: Communication)
enum AnnouncementStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  CANCELLED
}

model Announcement {
  id         String             @id @default(cuid())
  instituteId String?
  userId     String
  title      String
  message    String
  audience   String             @default("ALL")

// ─── Models ──────────────────────────────────────────────────────────────────

model Institute {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  ownerId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User? @relation("InstituteOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  users User[] @relation("InstituteUsers")

  @@index([ownerId])
  @@map("institutes")
}

model User {
  id         String    @id @default(cuid())
  instituteId String?
  name       String
  email      String    @unique
  password   String
  phone      String?
  role       Role      @default(STUDENT)
  avatar     String?
  isActive   Boolean   @default(true)
  isVerified Boolean   @default(false)
  lastLogin  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  sessions          Session[]
  accounts          Account[]
  activityLogs      ActivityLog[]
  notifications     Notification[]
  announcements     Announcement[]
  students          Student[]
  parents           Parent[]
  teacher           Teacher?
  studentActivities StudentActivity[] @relation("StudentActivityPerformedBy")
  institute         Institute? @relation("InstituteUsers", fields: [instituteId], references: [id], onDelete: Restrict)
  ownedInstitutes   Institute[] @relation("InstituteOwner")

  @@index([email])
  @@index([role])
  @@index([instituteId])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  instituteId String?
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([instituteId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model OTPVerification {
  id        String   @id @default(cuid())
  instituteId String?
  email     String
  otp       String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([instituteId])
  @@map("otp_verifications")
}

model ActivityLog {
  id String @id @default(cuid())
  instituteId String?

  // Who
  userId    String?
  userName  String?
  userRole  Role?
  ipAddress String?
  userAgent String?

  // What
  action   String
  category LogCategory @default(SYSTEM)
  severity LogSeverity @default(INFO)

  // On What
  entityType String?
  entityId   String?
  entityName String?

  // Details
  description String @default("")
  oldValue    Json?
  newValue    Json?
  metadata    Json?

  // Status
  isSuccessful Boolean @default(true)
  errorMessage String?

  createdAt DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([category])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([severity])
  @@index([instituteId])
  @@map("activity_logs")
}

// Password reset tokens stored separately for security
model PasswordResetToken {
  id        String   @id @default(cuid())
  instituteId String?
  email     String
  token     String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([instituteId])
  @@map("password_reset_tokens")
}

// ─── Module 2: Admin Dashboard ───────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  instituteId String?
  userId    String
  studentId String?
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([studentId])
  @@index([isRead])
  @@index([createdAt])
  @@index([instituteId])
  @@map("notifications")
}

model Enquiry {
  id            String @id @default(cuid())
  instituteId String?
  enquiryNumber String

  studentName  String
  studentAge   Int?
  studentClass String?
  parentName   String
  parentPhone  String
  parentEmail  String?
  address      String?

  interestedIn   String[]
  preferredBatch String?
  preferredTime  String?

  source       EnquirySource
  sourceDetail String?
  referredBy   String?

  status   EnquiryStatus @default(NEW)
  priority Priority      @default(NORMAL)

  assignedTo String?
  assignedAt DateTime?

  isConverted Boolean   @default(false)
  convertedAt DateTime?
  studentId   String?

  notes String?

  followUps   FollowUp[]
  demoClasses DemoClass[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instituteId, enquiryNumber])
  @@index([status])
  @@index([source])
  @@index([priority])
  @@index([assignedTo])
  @@index([createdAt])
  @@index([instituteId])
  @@map("enquiries")
}

model FollowUp {
  id             String         @id @default(cuid())
  instituteId String?
  enquiryId      String
  type           FollowUpType
  scheduledAt    DateTime
  completedAt    DateTime?
  status         FollowUpStatus @default(PENDING)
  notes          String?
  outcome        String?
  nextFollowUpAt DateTime?
  doneBy         String?

  enquiry Enquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([enquiryId])
  @@index([status])
  @@index([scheduledAt])
  @@index([instituteId])
  @@map("follow_ups")
}

model DemoClass {
  id             String     @id @default(cuid())
  instituteId String?
  enquiryId      String
  batchId        String?
  scheduledDate  DateTime
  scheduledTime  String
  status         DemoStatus @default(SCHEDULED)
  teacherNotes   String?
  parentFeedback String?
  interested     Boolean?

  enquiry Enquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enquiryId])
  @@index([status])
  @@index([scheduledDate])
  @@index([instituteId])
  @@map("demo_classes")
}

model DashboardAlert {
  id         String    @id @default(cuid())
  instituteId String?
  type       AlertType
  message    String
  severity   Severity
  isResolved Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([severity])
  @@index([isResolved])
  @@index([createdAt])
  @@index([instituteId])
  @@map("dashboard_alerts")
}

model InstituteSettings {
  id String @id @default(cuid())
  instituteId String?

  name        String
  tagline     String?
  description String?
  logo        String?
  favicon     String?

  phone          String?
  alternatePhone String?
  email          String?
  website        String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  pincode      String?
  country      String  @default("India")

  currentAcademicYear String
  academicYears       String[]
  workingDays         String[]
  workingHours        Json?

  gstEnabled    Boolean @default(false)
  gstNumber     String?
  gstPercentage Float   @default(18)
  panNumber     String?

  receiptPrefix      String  @default("RCP")
  receiptStartNumber String  @default("001")
  receiptFooterText  String?

  razorpayKeyId     String?
  razorpayKeySecret String?
  razorpayMode      String  @default("TEST")

  twilioAccountSid     String?
  twilioAuthToken      String?
  twilioWhatsAppNumber String?

  cloudinaryCloudName String?
  cloudinaryApiKey    String?
  cloudinaryApiSecret String?

  firebaseProjectId String?
  firebaseApiKey    String?

  passwordMinLength      Int     @default(8)
  requireUppercase       Boolean @default(true)
  requireNumber          Boolean @default(true)
  requireSpecialChar     Boolean @default(true)
  passwordExpiryDays     Int     @default(90)
  sessionTimeoutMinutes  Int     @default(30)
  rememberMeDays         Int     @default(7)
  maxFailedAttempts      Int     @default(5)
  lockoutDurationMinutes Int     @default(30)
  twoFactorEnabled       Boolean @default(false)

  autoBackupEnabled Boolean @default(false)
  backupFrequency   String  @default("WEEKLY")
  backupTime        String?
  backupRetention   Int     @default(10)

  currency   String @default("INR")
  dateFormat String @default("DD/MM/YYYY")
  timeFormat String @default("12H")
  language   String @default("EN")
  timezone   String @default("Asia/Kolkata")

  primaryColor   String @default("#2563EB")
  secondaryColor String @default("#10B981")

  onlinePaymentEnabled Boolean @default(false)
  qrAttendanceEnabled  Boolean @default(true)
  parentPortalEnabled  Boolean @default(true)
  studentPortalEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([instituteId])

  @@map("institute_settings")
}

model AcademicYear {
  id        String   @id @default(cuid())
  instituteId String?
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instituteId, name])
  @@index([isCurrent])
  @@index([isActive])
  @@index([instituteId])
  @@map("academic_years")
}

model BackupRecord {
  id          String       @id @default(cuid())
  instituteId String?
  fileName    String
  fileUrl     String?
  fileSize    String?
  type        BackupType
  status      BackupStatus @default(PENDING)
  triggeredBy String
  completedAt DateTime?
  errorMsg    String?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([instituteId])
  @@map("backup_records")
}

// ─── Module 3: Student Management ────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  GRADUATED
  TRANSFERRED
  ON_LEAVE
}

enum StudentCategory {
  WEAK
  AVERAGE
  GOOD
  TOPPER
}

enum DocumentType {
  BIRTH_CERTIFICATE
  SCHOOL_LEAVING
  MARKSHEET
  ID_PROOF
  ADDRESS_PROOF
  MEDICAL
  PHOTO
  OTHER
}

model Student {
  id String @id @default(cuid())
  instituteId String?

  studentCode  String
  firstName    String
  lastName     String
  email        String?
  phone        String?
  dateOfBirth  DateTime?
  gender       Gender
  bloodGroup   BloodGroup?
  profilePhoto String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  pincode      String?

  previousSchool String?
  previousClass  String?
  previousMarks  String?
  joiningDate    DateTime @default(now())
  academicYear   String

  status     StudentStatus   @default(ACTIVE)
  category   StudentCategory @default(AVERAGE)
  referredBy String?
  standardId String?

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  parentId String?
  parent   Parent? @relation(fields: [parentId], references: [id])

  batchEnrollments        BatchEnrollment[]
  attendance              Attendance[]
  attendanceAlerts        AttendanceAlert[]
  attendanceNotifications AttendanceNotification[]
  feeRecords              FeeRecord[]
  examResults             ExamResult[]
  studentAnswers          StudentAnswer[]
  onlineAttempts          OnlineAttempt[]
  reportCards             ReportCard[]
  performanceAnalyses     PerformanceAnalysis[]
  documents               StudentDocument[]
  emergencyContacts       EmergencyContact[]
  medicalInfo             MedicalInfo?
  siblings                SiblingLink[]            @relation("StudentSiblings")
  siblingOf               SiblingLink[]            @relation("SiblingOfStudent")
  notifications           Notification[]
  activities              StudentActivity[]
  // Reports relation
  studentProgressReports  StudentProgressReport[]
  ptmSlots                PTMSlot[]
  parentFeedbacks         ParentFeedback[]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  discounts           Discount[]
  scholarships        Scholarship[]
  refunds             Refund[]
  onlinePaymentOrders OnlinePaymentOrder[]
  standard            Standard?            @relation(fields: [standardId], references: [id], onDelete: SetNull)

  @@unique([instituteId, studentCode])
  @@unique([instituteId, email])
  @@index([studentCode])
  @@index([firstName, lastName])
  @@index([status])
  @@index([category])
  @@index([academicYear])
  @@index([standardId])
  @@index([instituteId])
  @@map("students")
}

model Standard {
  id       String  @id @default(cuid())
  instituteId String?
  name     String
  order    Int
  isActive Boolean @default(true)

  students                Student[]
  batches                 Batch[]
  exams                   Exam[]
  materials               StudyMaterial[]
  classSessions           ClassSession[]
  teacherStandardSubjects TeacherStandardSubject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instituteId, name])
  @@unique([instituteId, order])
  @@index([isActive])
  @@index([instituteId])
  @@map("standards")
}

model Parent {
  id             String  @id @default(cuid())
  instituteId String?
  parentCode     String?
  fatherName     String?
  fatherPhone    String?
  fatherEmail    String?
  fatherOccup    String?
  motherName     String?
  motherPhone    String?
  motherEmail    String?
  motherOccup    String?
  guardianName   String?
  guardianPhone  String?
  guardianRel    String?
  primaryContact String  @default("FATHER")

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  students Student[]

  ptmSlots  PTMSlot[]
  feedbacks ParentFeedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instituteId, parentCode])
  @@index([instituteId])

  @@map("parents")
}

model EmergencyContact {
  id           String  @id @default(cuid())
  instituteId String?
  studentId    String
  name         String
  relationship String
  phone        String
  isVerified   Boolean @default(false)

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([instituteId])
  @@map("emergency_contacts")
}

model MedicalInfo {
  id            String  @id @default(cuid())
  instituteId String?
  studentId     String  @unique
  allergies     String?
  medications   String?
  conditions    String?
  doctorName    String?
  doctorPhone   String?
  insuranceInfo String?
  extraNotes    String?

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([instituteId])

  @@map("medical_info")
}

model StudentDocument {
  id         String       @id @default(cuid())
  instituteId String?
  studentId  String
  name       String
  type       DocumentType
  fileUrl    String
  fileSize   String?
  uploadedAt DateTime     @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([instituteId])
  @@map("student_documents")
}

model SiblingLink {
  id        String @id @default(cuid())
  instituteId String?
  studentId String
  siblingId String

  student Student @relation("StudentSiblings", fields: [studentId], references: [id], onDelete: Cascade)
  sibling Student @relation("SiblingOfStudent", fields: [siblingId], references: [id], onDelete: Cascade)

  @@unique([studentId, siblingId])
  @@index([studentId])
  @@index([siblingId])
  @@index([instituteId])
  @@map("sibling_links")
}

model Attendance {
  id               String            @id @default(cuid())
  instituteId String?
  studentId        String
  batchId          String
  sessionId        String?
  date             DateTime
  markedAt         DateTime          @default(now())
  markedBy         String
  status           AttendanceStatus  @default(ABSENT)
  lateMinutes      Int?
  arrivalTime      String?
  isLeaveApproved  Boolean           @default(false)
  leaveReason      String?
  markedViaQR      Boolean           @default(false)
  qrToken          String?
  isCorrected      Boolean           @default(false)
  correctedBy      String?
  correctedAt      DateTime?
  originalStatus   AttendanceStatus?
  correctionReason String?
  parentNotified   Boolean           @default(false)
  notifiedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  student Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batch   Batch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  session ClassSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@unique([studentId, batchId, date])
  @@index([batchId, date])
  @@index([studentId, date])
  @@index([instituteId])
  @@map("attendance")
}


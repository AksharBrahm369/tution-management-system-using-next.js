// ─── Module 4: Teacher Management ────────────────────────────────────────────

model Teacher {
  id String @id @default(cuid())
  instituteId String?

  // Basic Info
  teacherCode    String
  firstName      String
  lastName       String
  email          String
  phone          String
  alternatePhone String?
  dateOfBirth    DateTime?
  gender         Gender
  bloodGroup     BloodGroup?
  profilePhoto   String?

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  pincode      String?

  // Professional Info
  qualification  String?
  specialization String?
  experience     Int?
  joiningDate    DateTime       @default(now())
  employmentType EmploymentType @default(FULL_TIME)

  // Salary Info
  salaryType     SalaryType @default(FIXED)
  fixedSalary    Float?
  perClassRate   Float?
  perStudentRate Float?

  // Bank Details
  bankName      String?
  accountNumber String?
  ifscCode      String?
  upiId         String?

  // Status
  status TeacherStatus @default(ACTIVE)

  // Login Access
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  // Relations
  subjects                  TeacherSubject[]
  standardSubjects          TeacherStandardSubject[]
  batches                   Batch[]
  attendance                TeacherAttendance[]
  leaves                    TeacherLeave[]
  salaryRecords             SalaryRecord[]
  documents                 TeacherDocument[]
  performance               TeacherPerformance[]
  // Reports relation
  teacherPerformanceReports TeacherPerformanceReport[]
  ptmSlots                  PTMSlot[]
  parentFeedbacks           ParentFeedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instituteId, teacherCode])
  @@unique([instituteId, email])
  @@index([instituteId])

  @@map("teachers")
}

model Subject {
  id          String  @id @default(cuid())
  instituteId String?
  name        String
  code        String
  description String?
  isActive    Boolean @default(true)

  teachers                TeacherSubject[]
  teacherStandardSubjects TeacherStandardSubject[]
  batches                 Batch[]
  exams                   Exam[]
  materials               StudyMaterial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instituteId, code])
  @@index([instituteId])

  @@map("subjects")
}

model StudyMaterial {
  id String @id @default(cuid())
  instituteId String?

  title        String
  description  String?
  subjectId    String?
  batchId      String?
  standardId   String?
  resourceType String
  accessLevel  String  @default("PUBLIC")
  resourceUrl  String?
  fileName     String?
  fileSize     String?
  createdBy    String?

  subject  Subject?  @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  batch    Batch?    @relation(fields: [batchId], references: [id], onDelete: SetNull)
  standard Standard? @relation(fields: [standardId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectId])
  @@index([batchId])
  @@index([standardId])
  @@index([accessLevel])
  @@index([instituteId])
  @@map("study_materials")
}

model TeacherSubject {
  id        String  @id @default(cuid())
  instituteId String?
  teacherId String
  subjectId String
  isPrimary Boolean @default(false)

  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  createdAt DateTime @default(now())

  @@unique([teacherId, subjectId])
  @@index([instituteId])
  @@map("teacher_subjects")
}

model TeacherStandardSubject {
  id         String @id @default(cuid())
  instituteId String?
  teacherId  String
  standardId String
  subjectId  String

  teacher  Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  standard Standard @relation(fields: [standardId], references: [id], onDelete: Cascade)
  subject  Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([teacherId, standardId, subjectId])
  @@index([standardId])
  @@index([subjectId])
  @@index([instituteId])
  @@map("teacher_standard_subjects")
}

model TeacherAttendance {
  id        String            @id @default(cuid())
  instituteId String?
  teacherId String
  date      DateTime
  status    TeacherAttdStatus @default(PRESENT)
  checkIn   DateTime?
  checkOut  DateTime?
  notes     String?
  markedBy  String

  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  createdAt DateTime @default(now())

  @@unique([teacherId, date])
  @@index([instituteId])
  @@map("teacher_attendance")
}

model TeacherLeave {
  id           String      @id @default(cuid())
  instituteId String?
  teacherId    String
  leaveType    LeaveType
  fromDate     DateTime
  toDate       DateTime
  totalDays    Int
  reason       String
  status       LeaveStatus @default(PENDING)
  reviewedBy   String?
  reviewNote   String?
  reviewedAt   DateTime?
  substituteId String?

  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([instituteId])

  @@map("teacher_leaves")
}

model SalaryRecord {
  id        String @id @default(cuid())
  instituteId String?
  teacherId String
  month     Int
  year      Int

  // Calculation
  baseSalary    Float
  classesHeld   Int   @default(0)
  studentCount  Int   @default(0)
  calculatedPay Float

  // Adjustments
  bonus       Float @default(0)
  deductions  Float @default(0)
  finalAmount Float

  // Payment
  status        PaymentStatus @default(PENDING)
  paidDate      DateTime?
  paymentMode   String?
  transactionId String?
  notes         String?

  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, month, year])
  @@index([instituteId])
  @@map("salary_records")
}

model TeacherDocument {
  id         String         @id @default(cuid())
  instituteId String?
  teacherId  String
  name       String
  type       TeacherDocType
  fileUrl    String
  fileSize   String?
  expiryDate DateTime?
  uploadedAt DateTime       @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id])
  @@index([instituteId])

  @@map("teacher_documents")
}

model TeacherPerformance {
  id        String @id @default(cuid())
  instituteId String?
  teacherId String
  month     Int
  year      Int

  // Metrics
  totalClasses     Int     @default(0)
  classesTaken     Int     @default(0)
  avgRating        Float?
  studentsFeedback String?
  adminNotes       String?

  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  createdAt DateTime @default(now())

  @@unique([teacherId, month, year])
  @@index([instituteId])
  @@map("teacher_performance")
}

// ─── Module 5: Batch & Schedule Management ───────────────────────────────────

model Room {
  id         String   @id @default(cuid())
  instituteId String?
  name       String
  code       String
  capacity   Int
  floor      String?
  building   String?
  facilities String[]
  isActive   Boolean  @default(true)

  batches  Batch[]
  sessions ClassSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instituteId, code])
  @@index([instituteId])

  @@map("rooms")
}

model Batch {
  id String @id @default(cuid())
  instituteId String?

  // Identity
  name        String
  code        String
  description String?
  color       String?

  // Subject and Teacher
  subjectId  String
  teacherId  String
  standardId String?

  // Schedule
  days            DayOfWeek[]
  startTime       String
  endTime         String
  durationMinutes Int         @default(0)

  // Room
  roomId String?

  // Capacity
  maxStrength     Int @default(30)
  currentStrength Int @default(0)

  // Academic
  academicYear String
  startDate    DateTime
  endDate      DateTime?
  fees         Float     @default(0)

  // Status
  status      BatchStatus @default(ACTIVE)
  isOnline    Boolean     @default(false)
  meetingLink String?

  // Relations
  subject                 Subject                  @relation(fields: [subjectId], references: [id])
  teacher                 Teacher                  @relation(fields: [teacherId], references: [id])
  standard                Standard?                @relation(fields: [standardId], references: [id], onDelete: SetNull)
  room                    Room?                    @relation(fields: [roomId], references: [id])
  enrollments             BatchEnrollment[]
  sessions                ClassSession[]
  attendance              Attendance[]
  attendanceSessions      AttendanceSession[]
  attendanceAlerts        AttendanceAlert[]
  attendanceNotifications AttendanceNotification[]
  timetableSlots          TimetableSlot[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  feeStructures FeeStructure[]
  feeRecords    FeeRecord[]
  exams         Exam[]
  materials     StudyMaterial[]

  @@unique([instituteId, code])
  @@index([code])
  @@index([status])
  @@index([academicYear])
  @@index([teacherId])
  @@index([subjectId])
  @@index([standardId])
  @@index([instituteId])
  @@map("batches")
}

model BatchEnrollment {
  id         String    @id @default(cuid())
  instituteId String?
  studentId  String
  batchId    String
  enrollDate DateTime  @default(now())
  leaveDate  DateTime?
  isActive   Boolean   @default(true)
  enrolledBy String
  notes      String?

  student Student @relation(fields: [studentId], references: [id])
  batch   Batch   @relation(fields: [batchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, batchId])
  @@index([studentId])
  @@index([batchId])
  @@index([instituteId])
  @@map("batch_enrollments")
}

model TimetableSlot {
  id        String    @id @default(cuid())
  instituteId String?
  batchId   String
  day       DayOfWeek
  startTime String
  endTime   String
  roomId    String?
  isActive  Boolean   @default(true)

  batch Batch @relation(fields: [batchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@index([instituteId])
  @@map("timetable_slots")
}

model ClassSession {
  id String @id @default(cuid())
  instituteId String?

  batchId    String
  teacherId  String
  roomId     String?
  standardId String?

  // Schedule
  date            DateTime
  startTime       String
  endTime         String
  durationMinutes Int

  // Content
  topic           String?
  description     String?
  homework        String?
  isAutoGenerated Boolean @default(false)

  // Status
  status       SessionStatus @default(SCHEDULED)
  cancelReason String?
  cancelledBy  String?
  cancelledAt  DateTime?

  // Reschedule
  isRescheduled    Boolean   @default(false)
  originalDate     DateTime?
  rescheduledTo    DateTime?
  rescheduleReason String?

  // Substitute
  hasSubstitute Boolean @default(false)
  substituteId  String?

  // Relations
  batch      Batch        @relation(fields: [batchId], references: [id])
  standard   Standard?    @relation(fields: [standardId], references: [id], onDelete: SetNull)
  room       Room?        @relation(fields: [roomId], references: [id])
  attendance Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@index([standardId])
  @@index([date])
  @@index([status])
  @@index([instituteId])
  @@map("class_sessions")
}

model Holiday {
  id          String      @id @default(cuid())
  instituteId String?
  name        String
  date        DateTime
  type        HolidayType
  description String?
  isRecurring Boolean     @default(false)
  affectsAll  Boolean     @default(true)
  batchIds    String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([instituteId])
  @@map("holidays")
}

model AcademicCalendar {
  id          String            @id @default(cuid())
  instituteId String?
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  type        CalendarEventType
  color       String?
  isAllDay    Boolean           @default(true)
  batchIds    String[]
  createdBy   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
  @@index([instituteId])
  @@map("academic_calendar")
}

model ConflictLog {
  id          String       @id @default(cuid())
  instituteId String?
  type        ConflictType
  description String
  batchId     String?
  teacherId   String?
  roomId      String?
  date        DateTime?
  timeSlot    String?
  isResolved  Boolean      @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?

  createdAt DateTime @default(now())

  @@index([isResolved])
  @@index([instituteId])
  @@map("conflict_logs")
}

// ─── Legacy ClassSchedule (kept for backward compatibility) ──────────────────

model ClassSchedule {
  id           String      @id @default(cuid())
  instituteId String?
  batchId      String
  date         DateTime
  startTime    String
  endTime      String
  topic        String?
  status       ClassStatus @default(SCHEDULED)
  cancelReason String?
  substituteId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([instituteId])

  @@map("class_schedules")
}
